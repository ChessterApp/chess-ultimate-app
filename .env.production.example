# ==========================================
# PRODUCTION Environment Variables
# ==========================================
# SECURITY: Copy this file to .env.production and fill in your values
# NEVER commit .env.production to git!
# ==========================================

# ===================
# Server Configuration
# ===================
CORS_ALLOWED_ORIGINS=http://YOUR_DROPLET_IP

# ===================
# Frontend Public URLs
# ===================
NEXT_PUBLIC_API_URL=http://YOUR_DROPLET_IP
NEXT_PUBLIC_BACKEND_URL=http://YOUR_DROPLET_IP

# ===================
# Clerk Authentication
# ===================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ===================
# Supabase Database
# ===================
# Get these from https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXX
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXX

# ===================
# AI Services
# ===================
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ===================
# Internal Service Authentication
# ===================
# Generate a strong random password for Redis
# Example: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_THIS_TO_A_STRONG_RANDOM_PASSWORD

# Generate a strong random API key for Weaviate
# Example: openssl rand -base64 32
WEAVIATE_API_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_API_KEY

# ===================
# Database Connection (for backend)
# ===================
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/chess_learning
