# ==========================================
# Chess Ultimate App - Backend Production Environment Template
# ==========================================
# Copy this file to `.env` and fill in your actual values
# NEVER commit the real `.env` file to version control

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=0
HOST=0.0.0.0
PORT=5001

# Secret key for Flask sessions
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# ==========================================
# Authentication & Database
# ==========================================

# Clerk Authentication (JWT verification)
# Get from: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Supabase Database
# Get from: https://app.supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ==========================================
# LLM Orchestration
# ==========================================

# OpenRouter API (provides access to multiple LLM providers)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Anthropic Claude (direct API)
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here

# OpenAI (alternative/fallback)
OPENAI_API_KEY=sk-your_openai_api_key_here

# LLM Configuration
PRIMARY_LLM_PROVIDER=openrouter
PRIMARY_MODEL=google/gemini-3-flash-preview
FALLBACK_LLM_PROVIDER=anthropic
FALLBACK_MODEL=claude-3-5-sonnet-20241022

# ==========================================
# Logging
# ==========================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/backend.log

# Enable LLM request/response logging
LOG_LLM_REQUESTS=true

# ==========================================
# CORS Configuration
# ==========================================

# CORS allowed origins (comma-separated)
# Production: use your production domain(s)
# Development: include http://localhost:3000
CORS_ALLOWED_ORIGINS=https://chesster.io,https://www.chesster.io

# ==========================================
# Custom-domain flow (Vercel Domains API)
# ==========================================
# See docs/prd/custom-domain-flow.md
# Real values populated post-merge by Alex from /root/clawd/CREDENTIALS.md.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_WEBHOOK_SECRET=

