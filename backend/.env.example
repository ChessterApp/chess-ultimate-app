# ==========================================
# Chess Ultimate App - Backend (Phase 1)
# ==========================================

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
HOST=0.0.0.0
PORT=5001

# Secret key for Flask sessions (generate a random string for production)
SECRET_KEY=your-secret-key-here-change-in-production

# ==========================================
# Phase 1: Authentication & Database
# ==========================================

# Clerk Authentication (JWT verification)
# Get this from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Supabase Database
# Get these from https://app.supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ==========================================
# Phase 1: LLM Orchestration
# ==========================================

# Anthropic Claude (recommended for chess tutoring)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (alternative/fallback)
OPENAI_API_KEY=your_openai_api_key_here

# LLM Configuration
PRIMARY_LLM_PROVIDER=anthropic
PRIMARY_MODEL=claude-3-5-sonnet-20241022
FALLBACK_LLM_PROVIDER=openai
FALLBACK_MODEL=gpt-4o

# ==========================================
# Phase 1: Logging
# ==========================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/backend.log

# Enable LLM request/response logging
LOG_LLM_REQUESTS=true

# ==========================================
# Phase 1: CORS Configuration
# ==========================================

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==========================================
# Custom-domain flow (Vercel Domains API)
# ==========================================
# See docs/prd/custom-domain-flow.md
# Token: dashboard.vercel.com → settings → tokens (scope: project + domains)
# Project ID + Team ID: dashboard.vercel.com → project → settings → general
# Webhook secret: dashboard.vercel.com → project → settings → webhooks
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_WEBHOOK_SECRET=

# ==========================================
# Chess Empire onboarding (Phase 1 — chess-empire.chesster.io)
# ==========================================
# Real values for production go in actual .env files (not committed).
# Shared with the frontend — same secrets, both processes consume them.
CHESS_EMPIRE_SERVICE_KEY=ce-api-2026-replace-me
CHESS_EMPIRE_SUPABASE_URL=https://papgcizhfkngubwofjuo.supabase.co
# Must match the frontend value — the verify route signs, the Clerk-webhook
# completion path (services/invite_jwt.py) verifies.
INVITE_JWT_SECRET=replace-with-random-secret

# ==========================================
# PHASE 2 - TO BE ENABLED LATER
# ==========================================

# Weaviate Vector Database (for 6M+ games semantic search)
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=
# WEAVIATE_SCHEME=http

# Redis (conversation cache and session management)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# TWIC Database
# TWIC_DATABASE_PATH=./data/twic/twic_master_database.pgn
# AUTO_UPDATE_TWIC=false

# RAG System
# TOP_K_RESULTS=10
# MIN_SIMILARITY_SCORE=0.7
# ENABLE_RAG_SYSTEM=true

# ==========================================
# REMOVED FROM PHASE 1
# ==========================================
# Stockfish engine (now handled by frontend WASM)
# Voice services (deferred to future phase)
# SocketIO/UCI routes (not needed for Phase 1)
