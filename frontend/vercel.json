{
  "headers": [
    {
      "source": "/maia-worker.js",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" }
      ]
    },
    {
      "source": "/ort/(.*)",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/openings/:path*", "destination": "https://api.chesster.io/api/openings/:path*" },
    { "source": "/api/chat/analysis", "destination": "https://api.chesster.io/api/chat/analysis" },
    { "source": "/api/chat/analysis/stream", "destination": "https://api.chesster.io/api/chat/analysis/stream" },
    { "source": "/api/chat/history/:path*", "destination": "https://api.chesster.io/api/chat/history/:path*" },
    { "source": "/api/courses/:path*", "destination": "https://api.chesster.io/api/courses/:path*" },
    { "source": "/api/learn/:path*", "destination": "https://api.chesster.io/api/learn/:path*" },
    { "source": "/api/puzzles/:path*", "destination": "https://api.chesster.io/api/puzzles/:path*" },
    { "source": "/api/opponent/:path*", "destination": "https://api.chesster.io/api/opponent/:path*" },
    { "source": "/api/user/:path*", "destination": "https://api.chesster.io/api/user/:path*" },
    { "source": "/api/scoresheet/:path*", "destination": "https://api.chesster.io/api/scoresheet/:path*" },
    { "source": "/api/games/:path*", "destination": "https://api.chesster.io/api/games/:path*" },
    { "source": "/api/games", "destination": "https://api.chesster.io/api/games" },
    { "source": "/api/explorer/:path*", "destination": "https://api.chesster.io/api/explorer/:path*" }
  ]
}
